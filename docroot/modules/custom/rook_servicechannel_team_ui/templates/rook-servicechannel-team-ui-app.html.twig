<section class="rook-team-ui" data-rook-team-ui>
  <header class="rook-team-ui__header">
    <div>
      <p class="rook-team-ui__eyebrow">Service workspace</p>
      <h1 class="rook-team-ui__title">RooK Service Channel</h1>
      <p class="rook-team-ui__subtitle">Couple a support session by PIN and open the browser terminal against the configured gateway.</p>
    </div>
  </header>

  <div class="rook-team-ui__grid">
    <section class="rook-team-ui__card rook-team-ui__card--controls">
      <h2>Session</h2>

      <form class="rook-team-ui__form" data-rook-pin-form>
        <label class="rook-team-ui__label" for="rook-team-ui-pin">Session PIN</label>
        <input id="rook-team-ui-pin" class="rook-team-ui__input" type="text" autocomplete="off" inputmode="numeric" data-rook-pin-input />

        <div class="rook-team-ui__actions">
          <button class="button button--primary" type="submit" data-rook-pin-submit>Couple session</button>
          <button class="button" type="button" data-rook-status-refresh>Refresh status</button>
          <button class="button button--primary" type="button" data-rook-open-terminal disabled>Open terminal</button>
          <button class="button" type="button" data-rook-close-terminal disabled>Disconnect terminal</button>
        </div>
      </form>

      <dl class="rook-team-ui__facts">
        <div>
          <dt>API state</dt>
          <dd data-rook-api-state>Idle</dd>
        </div>
        <div>
          <dt>Session status</dt>
          <dd data-rook-session-status>Unknown</dd>
        </div>
        <div>
          <dt>Terminal state</dt>
          <dd data-rook-terminal-state>Disconnected</dd>
        </div>
      </dl>

      <div class="rook-team-ui__message" data-rook-ui-message hidden></div>
    </section>

    <section class="rook-team-ui__card rook-team-ui__card--terminal">
      <div class="rook-team-ui__terminal-header">
        <div>
          <h2>Browser terminal</h2>
          <p class="rook-team-ui__hint">The UI uses the existing client API, then authorizes the browser terminal over WebSocket with an initial <code>authorize</code> message.</p>
        </div>
      </div>

      <div class="rook-team-ui__terminal-shell">
        <div class="rook-team-ui__terminal" data-rook-terminal></div>
      </div>
    </section>
  </div>
</section>
